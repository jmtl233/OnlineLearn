{"remainingRequest":"E:\\OnlineLearn\\OnlineLearnVue\\node_modules\\vue-loader\\lib\\index.js??vue-loader-options!E:\\OnlineLearn\\OnlineLearnVue\\src\\views\\studentweb\\essentialinformation\\EssentiaInfo.vue?vue&type=style&index=0&id=3f16473e&scoped=true&lang=css&","dependencies":[{"path":"E:\\OnlineLearn\\OnlineLearnVue\\src\\views\\studentweb\\essentialinformation\\EssentiaInfo.vue","mtime":1744733270322},{"path":"E:\\OnlineLearn\\OnlineLearnVue\\node_modules\\css-loader\\dist\\cjs.js","mtime":1711182487975},{"path":"E:\\OnlineLearn\\OnlineLearnVue\\node_modules\\vue-loader\\lib\\loaders\\stylePostLoader.js","mtime":1711182506221},{"path":"E:\\OnlineLearn\\OnlineLearnVue\\node_modules\\postcss-loader\\src\\index.js","mtime":1711182496599},{"path":"E:\\OnlineLearn\\OnlineLearnVue\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1711182484313},{"path":"E:\\OnlineLearn\\OnlineLearnVue\\node_modules\\vue-loader\\lib\\index.js","mtime":1711182506214}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["EssentiaInfo.vue"],"names":[],"mappings":";;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;AA4RA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA","file":"EssentiaInfo.vue","sourceRoot":"src/views/studentweb/essentialinformation","sourcesContent":["<template>\r\n    <div class=\"personal-container\">\r\n        <!-- 基本信息展示 -->\r\n        <el-card class=\"info-card\">\r\n            <div class=\"card-header\">\r\n                <h2>个人信息中心</h2>\r\n                <div class=\"operation-buttons\">\r\n                    <el-button type=\"primary\" size=\"small\" @click=\"dialogFormVisible = true\">编辑信息</el-button>\r\n                    <el-button type=\"warning\" size=\"small\" @click=\"showPasswordDialog = true\">修改密码</el-button>\r\n                </div>\r\n            </div>\r\n\r\n            <el-divider></el-divider>\r\n\r\n            <el-descriptions class=\"info-table\" :column=\"3\" border>\r\n                <el-descriptions-item label=\"用户名\">\r\n                    <i class=\"el-icon-user\"></i>\r\n                    {{ Info.userName }}\r\n                </el-descriptions-item>\r\n\r\n                <el-descriptions-item label=\"手机号\">\r\n                    <i class=\"el-icon-mobile-phone\"></i>\r\n                    {{ Info.phone }}\r\n                </el-descriptions-item>\r\n\r\n                <el-descriptions-item label=\"性别\">\r\n                    <i class=\"el-icon-male\"></i>\r\n                    {{ genderDisplay }}\r\n                </el-descriptions-item>\r\n\r\n                <el-descriptions-item label=\"电子邮箱\">\r\n                    <i class=\"el-icon-message\"></i>\r\n                    {{ Info.email || '未填写' }}\r\n                </el-descriptions-item>\r\n\r\n                <el-descriptions-item label=\"出生日期\">\r\n                    <i class=\"el-icon-date\"></i>\r\n                    {{ Info.birthday || '未填写' }}\r\n                </el-descriptions-item>\r\n\r\n                <el-descriptions-item label=\"注册时间\">\r\n                    <i class=\"el-icon-time\"></i>\r\n                    {{ formattedCreateTime }}\r\n                </el-descriptions-item>\r\n\r\n                <el-descriptions-item label=\"所属院系\">\r\n                    <i class=\"el-icon-office-building\"></i>\r\n                    {{ Info.department || '未填写' }}\r\n                </el-descriptions-item>\r\n\r\n                <el-descriptions-item label=\"专业班级\">\r\n                    <i class=\"el-icon-s-order\"></i>\r\n                    {{ Info.majorClass || '未填写' }}\r\n                </el-descriptions-item>\r\n\r\n                <el-descriptions-item label=\"政治面貌\">\r\n                    <i class=\"el-icon-star-on\"></i>\r\n                    {{ Info.politicalStatus || '未填写' }}\r\n                </el-descriptions-item>\r\n            </el-descriptions>\r\n        </el-card>\r\n\r\n        <!-- 编辑信息对话框 -->\r\n        <el-dialog title=\"编辑个人信息\" :visible.sync=\"dialogFormVisible\" width=\"50%\">\r\n            <el-form :model=\"Info\" :rules=\"rules\" ref=\"editForm\" label-width=\"100px\">\r\n                <el-row :gutter=\"20\">\r\n                    <el-col :span=\"12\">\r\n                        <el-form-item label=\"用户名\" prop=\"userName\">\r\n                            <el-input v-model=\"Info.userName\" placeholder=\"请输入姓名\"></el-input>\r\n                        </el-form-item>\r\n                        <el-form-item label=\"性别\" prop=\"sex\">\r\n                            <el-radio-group v-model=\"Info.sex\">\r\n                                <el-radio :label=\"0\">男</el-radio>\r\n                                <el-radio :label=\"1\">女</el-radio>\r\n                            </el-radio-group>\r\n                        </el-form-item>\r\n                        <el-form-item label=\"出生日期\">\r\n                            <el-date-picker\r\n                                v-model=\"Info.birthday\"\r\n                                type=\"date\"\r\n                                placeholder=\"选择日期\"\r\n                                value-format=\"yyyy-MM-dd\"\r\n                                style=\"width: 100%\">\r\n                            </el-date-picker>\r\n                        </el-form-item>\r\n                    </el-col>\r\n                    <el-col :span=\"12\">\r\n                        <el-form-item label=\"手机号\" prop=\"phone\">\r\n                            <el-input v-model=\"Info.phone\"></el-input>\r\n                        </el-form-item>\r\n                        <el-form-item label=\"电子邮箱\" prop=\"email\">\r\n                            <el-input v-model=\"Info.email\"></el-input>\r\n                        </el-form-item>\r\n                        <el-form-item label=\"政治面貌\">\r\n                            <el-select v-model=\"Info.politicalStatus\" placeholder=\"请选择\" style=\"width: 100%\">\r\n                                <el-option label=\"群众\" value=\"群众\"></el-option>\r\n                                <el-option label=\"共青团员\" value=\"共青团员\"></el-option>\r\n                                <el-option label=\"中共党员\" value=\"中共党员\"></el-option>\r\n                            </el-select>\r\n                        </el-form-item>\r\n                    </el-col>\r\n                </el-row>\r\n                <el-form-item label=\"所属院系\">\r\n                    <el-input v-model=\"Info.department\"></el-input>\r\n                </el-form-item>\r\n                <el-form-item label=\"专业班级\">\r\n                    <el-input v-model=\"Info.majorClass\"></el-input>\r\n                </el-form-item>\r\n            </el-form>\r\n            <div slot=\"footer\">\r\n                <el-button @click=\"dialogFormVisible = false\">取消</el-button>\r\n                <el-button type=\"primary\" @click=\"submitForm\" :loading=\"submitting\">保存修改</el-button>\r\n            </div>\r\n        </el-dialog>\r\n\r\n        <!-- 修改密码对话框（保持原样） -->\r\n        <el-dialog title=\"修改密码\" :visible.sync=\"showPasswordDialog\" width=\"30%\">\r\n            <el-form :model=\"passwordForm\" :rules=\"passwordRules\" ref=\"passwordForm\">\r\n                <el-form-item label=\"原密码\" prop=\"oldPassword\" label-width=\"100px\">\r\n                    <el-input v-model=\"passwordForm.oldPassword\" type=\"password\" show-password></el-input>\r\n                </el-form-item>\r\n                <el-form-item label=\"新密码\" prop=\"newPassword\" label-width=\"100px\">\r\n                    <el-input v-model=\"passwordForm.newPassword\" type=\"password\" show-password></el-input>\r\n                </el-form-item>\r\n                <el-form-item label=\"确认密码\" prop=\"confirmPassword\" label-width=\"100px\">\r\n                    <el-input v-model=\"passwordForm.confirmPassword\" type=\"password\" show-password></el-input>\r\n                </el-form-item>\r\n            </el-form>\r\n            <div slot=\"footer\">\r\n                <el-button @click=\"showPasswordDialog = false\">取消</el-button>\r\n                <el-button type=\"primary\" @click=\"submitPassword\" :loading=\"changingPassword\">确认修改</el-button>\r\n            </div>\r\n        </el-dialog>\r\n    </div>\r\n</template>\r\n\r\n<script>\r\nimport { personal, updateInfo, changePassword } from '../../../api/personal.js'\r\nimport Cookies from 'js-cookie'\r\nimport moment from 'moment'\r\n\r\nexport default {\r\n    name: \"StudentInfo\",\r\n    data() {\r\n        const validatePhone = (rule, value, callback) => {\r\n            if (!/^1[3-9]\\d{9}$/.test(value)) {\r\n                callback(new Error('请输入有效的手机号码'))\r\n            } else {\r\n                callback()\r\n            }\r\n        }\r\n        const validateEmail = (rule, value, callback) => {\r\n            if (value && !/^\\w+([-+.]\\w+)*@\\w+([-.]\\w+)*\\.\\w+([-.]\\w+)*$/.test(value)) {\r\n                callback(new Error('请输入有效的邮箱地址'))\r\n            } else {\r\n                callback()\r\n            }\r\n        }\r\n\r\n        return {\r\n            Info: {\r\n                userName: '',\r\n                phone: '',\r\n                sex: 0,\r\n                email: '',\r\n                birthday: '',\r\n                department: '',\r\n                majorClass: '',\r\n                politicalStatus: '',\r\n                createTime: ''\r\n            },\r\n            passwordForm: {\r\n                oldPassword: '',\r\n                newPassword: '',\r\n                confirmPassword: ''\r\n            },\r\n            rules: {\r\n                userName: [\r\n                    { required: true, message: '请输入用户名', trigger: 'blur' },\r\n                    { min: 2, max: 12, message: '长度在2到12个字符', trigger: 'blur' }\r\n                ],\r\n                phone: [\r\n                    { required: true, message: '请输入手机号', trigger: 'blur' },\r\n                    { validator: validatePhone, trigger: 'blur' }\r\n                ],\r\n                email: [\r\n                    { validator: validateEmail, trigger: 'blur' }\r\n                ]\r\n            },\r\n            passwordRules: {\r\n                oldPassword: [\r\n                    { required: true, message: '请输入原密码', trigger: 'blur' }\r\n                ],\r\n                newPassword: [\r\n                    { required: true, message: '请输入新密码', trigger: 'blur' },\r\n                    { min: 6, max: 20, message: '密码长度6-20位', trigger: 'blur' }\r\n                ],\r\n                confirmPassword: [\r\n                    { required: true, message: '请再次输入密码', trigger: 'blur' },\r\n                    { validator: (rule, value, callback) => {\r\n                            if (value !== this.passwordForm.newPassword) {\r\n                                callback(new Error('两次输入密码不一致!'))\r\n                            } else {\r\n                                callback()\r\n                            }\r\n                        }, trigger: 'blur' }\r\n                ]\r\n            },\r\n            dialogFormVisible: false,\r\n            showPasswordDialog: false,\r\n            submitting: false,\r\n            changingPassword: false\r\n        }\r\n    },\r\n    computed: {\r\n        genderDisplay() {\r\n            return this.Info.sex === 0 ? '男' : '女'\r\n        },\r\n        formattedCreateTime() {\r\n            return moment(this.Info.createTime).format('YYYY-MM-DD HH:mm:ss')\r\n        }\r\n    },\r\n    created() {\r\n        this.fetchUserInfo()\r\n    },\r\n    methods: {\r\n        async fetchUserInfo() {\r\n            try {\r\n                const userId = Cookies.get(\"userId\")\r\n                const res = await personal({ id: userId })\r\n                // 合并接口返回数据与本地数据模型\r\n                this.Info = { ...this.Info, ...res.data.resultData }\r\n            } catch (error) {\r\n                this.$message.error('获取用户信息失败')\r\n            }\r\n        },\r\n        async submitForm() {\r\n            try {\r\n                this.submitting = true\r\n                await this.$refs.editForm.validate()\r\n\r\n                const res = await updateInfo(this.Info)\r\n                if (res.data.code === 200) {\r\n                    this.$message.success('信息更新成功')\r\n                    this.dialogFormVisible = false\r\n                    this.fetchUserInfo()\r\n                }\r\n            } catch (error) {\r\n                console.error('提交失败', error)\r\n            } finally {\r\n                this.submitting = false\r\n            }\r\n        },\r\n        async submitPassword() {\r\n            try {\r\n                this.changingPassword = true\r\n                await this.$refs.passwordForm.validate()\r\n\r\n                const params = {\r\n                    oldPassword: this.passwordForm.oldPassword,\r\n                    newPassword: this.passwordForm.newPassword\r\n                }\r\n\r\n                const res = await changePassword(params)\r\n                if (res.data.code === 200) {\r\n                    this.$message.success('密码修改成功')\r\n                    this.showPasswordDialog = false\r\n                    this.passwordForm = {\r\n                        oldPassword: '',\r\n                        newPassword: '',\r\n                        confirmPassword: ''\r\n                    }\r\n                }\r\n            } catch (error) {\r\n                console.error(error)\r\n            } finally {\r\n                this.changingPassword = false\r\n            }\r\n        }\r\n    }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n.personal-container {\r\n    height: calc(100vh - 60px);\r\n    padding: 20px;\r\n    background-color: #f5f7fa;\r\n}\r\n\r\n.info-card {\r\n    height: 100%;\r\n    box-shadow: 0 2px 12px 0 rgba(0,0,0,0.1);\r\n}\r\n\r\n.card-header {\r\n    display: flex;\r\n    justify-content: space-between;\r\n    align-items: center;\r\n    padding: 0 20px 20px;\r\n}\r\n\r\n.operation-buttons {\r\n    margin-top: -10px;\r\n}\r\n\r\n.info-table {\r\n    margin-top: 20px;\r\n}\r\n\r\n::v-deep .el-descriptions-item__label {\r\n    width: 120px;\r\n    background-color: #f8f9fa !important;\r\n}\r\n\r\n::v-deep .el-descriptions-item__content {\r\n    padding-left: 30px;\r\n}\r\n\r\n.el-icon-user,\r\n.el-icon-mobile-phone,\r\n.el-icon-male,\r\n.el-icon-time,\r\n.el-icon-message,\r\n.el-icon-date,\r\n.el-icon-office-building,\r\n.el-icon-s-order,\r\n.el-icon-star-on {\r\n    margin-right: 8px;\r\n    color: #409EFF;\r\n    font-size: 16px;\r\n}\r\n\r\n.el-divider {\r\n    margin: 15px 0;\r\n}\r\n</style>"]}]}